%% ========================================================================
%% NAVIGATION FSM - Interface LVGL Ecran_Strategie_V4
%% Diagramme d'états de la navigation utilisateur
%% Version: v0.1
%% ========================================================================

stateDiagram-v2
    direction TB

    %% ====================================================================
    %% ÉTAT INITIAL - BOOT SEQUENCE
    %% ====================================================================

    [*] --> BOOT: System Reset

    BOOT: 🚀 BOOT SEQUENCE
    BOOT: Ihm Constructor
    BOOT: Create tabView (4 tabs)
    BOOT: Initialize LVGL objects

    %% ====================================================================
    %% ÉCRANS PRINCIPAUX - TABS
    %% ====================================================================

    state TAB_VIEW {
        [*] --> TAB_CARTESD

        TAB_CARTESD: 📂 Tab 1: CarteSD Status
        TAB_CARTESD: - spinnerCarteSD (loading)
        TAB_CARTESD: - labelCarteSDStatus
        TAB_CARTESD: - labelCarteSDFileCount
        TAB_CARTESD: Waits for SD card detection

        TAB_MATCH: 🎯 Tab 2: Match/Strategy
        TAB_MATCH: - roller (strategy file selector)
        TAB_MATCH: - couleur (Jaune/Bleu button)
        TAB_MATCH: - depart (GO button)
        TAB_MATCH: Main control interface

        TAB_ACTIONNEUR: 🔧 Tab 3: Test Actionneur
        TAB_ACTIONNEUR: - btnTestVentouses
        TAB_ACTIONNEUR: Actuator testing interface
        TAB_ACTIONNEUR: (Legacy buttons commented out)

        TAB_TEST: ⚠️ Tab 4: Test (NOT IMPLEMENTED)
        TAB_TEST: testTabInit() declared but undefined
        TAB_TEST: Empty tab - placeholder

        %% Transitions entre tabs (manuelles)
        TAB_CARTESD --> TAB_MATCH: User clicks tab 2
        TAB_CARTESD --> TAB_ACTIONNEUR: User clicks tab 3
        TAB_CARTESD --> TAB_TEST: User clicks tab 4

        TAB_MATCH --> TAB_CARTESD: User clicks tab 1
        TAB_MATCH --> TAB_ACTIONNEUR: User clicks tab 3
        TAB_MATCH --> TAB_TEST: User clicks tab 4

        TAB_ACTIONNEUR --> TAB_CARTESD: User clicks tab 1
        TAB_ACTIONNEUR --> TAB_MATCH: User clicks tab 2
        TAB_ACTIONNEUR --> TAB_TEST: User clicks tab 4

        TAB_TEST --> TAB_CARTESD: User clicks tab 1
        TAB_TEST --> TAB_MATCH: User clicks tab 2
        TAB_TEST --> TAB_ACTIONNEUR: User clicks tab 3
    }

    BOOT --> TAB_VIEW: carteSDInit()<br/>show()<br/>ActionneurInit()
    TAB_VIEW --> AUTO_SWITCH: SD files loaded

    %% Auto-switch programmatique
    AUTO_SWITCH: 🔄 Auto Tab Switch
    AUTO_SWITCH: lv_tabview_set_act(tabView, 1)
    AUTO_SWITCH: Switches to Tab 2 automatically

    AUTO_SWITCH --> IDLE_MATCH: Tab 2 shown

    %% ====================================================================
    %% ÉTAT IDLE - ATTENTE UTILISATEUR
    %% ====================================================================

    IDLE_MATCH: 💤 IDLE - Tab 2 Active
    IDLE_MATCH: State: multi_init
    IDLE_MATCH: Waiting for user action
    IDLE_MATCH: User can select strategy & color

    %% ====================================================================
    %% FLUX MATCH - DÉMARRAGE COMPÉTITION
    %% ====================================================================

    state MATCH_FLOW {
        [*] --> MATCH_TRIGGER

        MATCH_TRIGGER: 🚦 GO Button Clicked
        MATCH_TRIGGER: Event: LV_EVENT_CLICKED on depart
        MATCH_TRIGGER: Action: Set IHM_FLAG_DEPART
        MATCH_TRIGGER: Store departCouleur & departStrategie

        MATCH_TRIGGER --> MATCH_OVERLAY: eventHandler()

        MATCH_OVERLAY: 📋 Match Message Box
        MATCH_OVERLAY: msgBoxmatchshow()
        MATCH_OVERLAY: Display strategy + color
        MATCH_OVERLAY: Modal overlay (no buttons)
        MATCH_OVERLAY: Blocks all interaction

        MATCH_OVERLAY --> MATCH_RUNNING: run_show() thread starts

        MATCH_RUNNING: ⚡ Match Execution
        MATCH_RUNNING: State: show_run_page
        MATCH_RUNNING: Thread executes machineStrategie()
        MATCH_RUNNING: 100 second timer
        MATCH_RUNNING: CAN commands sent
        MATCH_RUNNING: ⚠️ TERMINAL STATE

        MATCH_RUNNING --> MATCH_END: Match timer expires

        MATCH_END: 🏁 Match Complete
        MATCH_END: msgBoxmatchshowclose()
        MATCH_END: Remove overlay
        MATCH_END: NVIC_SystemReset()
    }

    IDLE_MATCH --> MATCH_FLOW: Click GO button
    MATCH_FLOW --> [*]: System Reset

    %% ====================================================================
    %% FLUX VENTOUSES - NOUVEAU SYSTÈME (3 NIVEAUX)
    %% ====================================================================

    state VACUUM_TEST {
        [*] --> VACUUM_L1

        VACUUM_L1: 🔵 Vacuum Test - Level 1
        VACUUM_L1: showVentousesNiveau1()
        VACUUM_L1: Select side:
        VACUUM_L1: - Gauche (left)
        VACUUM_L1: - Droite (right)
        VACUUM_L1: - Les Deux (both)

        VACUUM_L1 --> VACUUM_L2: Select side<br/>ventousesNiveau1EventHandler()

        VACUUM_L2: 🟢 Vacuum Test - Level 2
        VACUUM_L2: showVentousesNiveau2(cote)
        VACUUM_L2: Select vacuum number:
        VACUUM_L2: - Ventouse 1/2/3/4
        VACUUM_L2: - Annuler (cancel)

        VACUUM_L2 --> VACUUM_L1: Click Annuler<br/>closeVentousesMenu()
        VACUUM_L2 --> VACUUM_L3: Select number<br/>ventousesNiveau2EventHandler()

        VACUUM_L3: 🟡 Vacuum Test - Level 3
        VACUUM_L3: showVentousesNiveau3(cote, numero)
        VACUUM_L3: Select action:
        VACUUM_L3: - Attraper (grab)
        VACUUM_L3: - Lâcher (release)
        VACUUM_L3: - Les Deux (both)
        VACUUM_L3: - Annuler (cancel)

        VACUUM_L3 --> VACUUM_L2: Click Annuler<br/>showVentousesNiveau2()
        VACUUM_L3 --> VACUUM_EXEC: Select action<br/>ventousesNiveau3EventHandler()

        VACUUM_EXEC: ⚙️ Execute Vacuum Command
        VACUUM_EXEC: executeVentouse()
        VACUUM_EXEC: Send CAN command
        VACUUM_EXEC: threadCAN.sendVentouse(...)

        VACUUM_EXEC --> [*]: closeVentousesMenu()<br/>Return to Tab 3
    }

    %% ====================================================================
    %% FLUX ACTIONNEURS LEGACY - SYSTÈME ANCIEN (COMMENTÉ)
    %% ====================================================================

    state LEGACY_TEST {
        [*] --> LEGACY_TRIGGER

        note right of LEGACY_TRIGGER
            ⚠️ CODE COMMENTÉ - LEGACY FLOW
            Anciennement utilisé pour tests actionneurs
            Désactivé dans version v0.1
        end note

        LEGACY_TRIGGER: 🔘 Test Button Clicked
        LEGACY_TRIGGER: Buttons (COMMENTED OUT):
        LEGACY_TRIGGER: - Test_ventouse
        LEGACY_TRIGGER: - construction_niveaux_2
        LEGACY_TRIGGER: - niveaux_base
        LEGACY_TRIGGER: - Position_init
        LEGACY_TRIGGER: - lacher
        LEGACY_TRIGGER: Set IHM_FLAG_*

        LEGACY_TRIGGER --> LEGACY_SIDE: eventHandler()

        LEGACY_SIDE: 🤖 Robot Side Selection
        LEGACY_SIDE: showButtonascenceurBox()
        LEGACY_SIDE: Buttons:
        LEGACY_SIDE: - Avant (front)
        LEGACY_SIDE: - Arrière (rear)
        LEGACY_SIDE: - Les Deux (both)
        LEGACY_SIDE: - Annuler (cancel = RESET!)
        LEGACY_SIDE: Timeout: 5 seconds

        LEGACY_SIDE --> LEGACY_RESET: Click Annuler<br/>NVIC_SystemReset()
        LEGACY_SIDE --> LEGACY_LEVEL: Select side<br/>selection_ascenseur_event_handler()

        LEGACY_LEVEL: 🎚️ Level Selection Matrix
        LEGACY_LEVEL: showButtonSelectionBox()
        LEGACY_LEVEL: 8 buttons:
        LEGACY_LEVEL: Niveaux 1/2, Stable, Tout
        LEGACY_LEVEL: Ventouse bas/haut, Tt Ventouse
        LEGACY_LEVEL: Aucun
        LEGACY_LEVEL: Timeout: 5 seconds

        LEGACY_LEVEL --> LEGACY_EXEC: Select level<br/>selection_event_handler()

        LEGACY_EXEC: ⚡ Execute Actuator Test
        LEGACY_EXEC: State: test
        LEGACY_EXEC: msgBoxInit("Test en cours")
        LEGACY_EXEC: threadCAN.sendAck(...)
        LEGACY_EXEC: Wait 3 seconds
        LEGACY_EXEC: msgBoxClose()

        LEGACY_EXEC --> [*]: State → multi_init<br/>Return to idle

        LEGACY_RESET: 🔄 SYSTEM RESET
        LEGACY_RESET: NVIC_SystemReset()
        LEGACY_RESET: Reboot STM32
    }

    LEGACY_RESET --> [*]

    %% ====================================================================
    %% MESSAGE BOXES OVERLAY
    %% ====================================================================

    state MSGBOXES {
        MSGBOX_RECALAGE: 📐 msgBoxRecalage
        MSGBOX_RECALAGE: Calibration confirmation
        MSGBOX_RECALAGE: Shows strategy + color
        MSGBOX_RECALAGE: Button: Ok

        MSGBOX_JACK: 🔌 msgBoxJack
        MSGBOX_JACK: Jack removal warning
        MSGBOX_JACK: "Enlever le jack pour démarrer"
        MSGBOX_JACK: Button: Jack simulé

        MSGBOX_GENERIC: 💬 msgBox (Generic)
        MSGBOX_GENERIC: Configurable message box
        MSGBOX_GENERIC: msgBoxInit(title, msg, cancel)
        MSGBOX_GENERIC: Used for status messages
    }

    note right of MSGBOXES
        Message boxes are MODAL overlays
        Appear on top of tab view
        Block interaction with tabs
        Used for warnings, confirmations, status
    end note

    %% ====================================================================
    %% TRANSITIONS PRINCIPALES
    %% ====================================================================

    %% Tab 3 → Vacuum Test
    TAB_VIEW --> VACUUM_TEST: Click btnTestVentouses<br/>on Tab 3
    VACUUM_TEST --> TAB_VIEW: Test complete or cancel

    %% Tab 3 → Legacy Test (commenté)
    note left of LEGACY_TEST
        Legacy flow is currently DISABLED
        Code exists but is commented out
        Previously triggered from Tab 3 buttons
    end note

    %% ====================================================================
    %% ÉTATS TERMINAUX
    %% ====================================================================

    note right of MATCH_RUNNING
        ⚠️ TERMINAL STATE
        Cannot exit match once started
        No back button, no cancel
        Only way out: system reset at end
        UI locked with modal overlay
    end note

    %% ====================================================================
    %% LÉGENDE DES SYMBOLES
    %% ====================================================================

    classDef bootState fill:#e3f2fd,stroke:#1976d2,stroke-width:3px,color:#000
    classDef idleState fill:#fff9c4,stroke:#f57f17,stroke-width:2px,color:#000
    classDef tabState fill:#e8eaf6,stroke:#3f51b5,stroke-width:2px,color:#000
    classDef runningState fill:#ffebee,stroke:#c62828,stroke-width:3px,color:#000
    classDef testState fill:#e0f2f1,stroke:#00695c,stroke-width:2px,color:#000
    classDef msgboxState fill:#fce4ec,stroke:#880e4f,stroke-width:2px,color:#000
    classDef terminalState fill:#ffcdd2,stroke:#b71c1c,stroke-width:4px,color:#000
    classDef legacyState fill:#f5f5f5,stroke:#616161,stroke-width:1px,stroke-dasharray: 5 5,color:#666

    class BOOT bootState
    class IDLE_MATCH idleState
    class TAB_CARTESD,TAB_MATCH,TAB_ACTIONNEUR,TAB_TEST,AUTO_SWITCH tabState
    class MATCH_TRIGGER,MATCH_OVERLAY,MATCH_END runningState
    class MATCH_RUNNING terminalState
    class VACUUM_L1,VACUUM_L2,VACUUM_L3,VACUUM_EXEC testState
    class MSGBOX_RECALAGE,MSGBOX_JACK,MSGBOX_GENERIC msgboxState
    class LEGACY_TRIGGER,LEGACY_SIDE,LEGACY_LEVEL,LEGACY_EXEC,LEGACY_RESET legacyState

%% ========================================================================
%% LÉGENDE COMPLÈTE - NAVIGATION LVGL
%% ========================================================================
%%
%% COULEURS DES ÉTATS:
%%   - BLEU CLAIR (bootState)      : Boot sequence et initialisation
%%   - JAUNE (idleState)            : État idle - attente utilisateur
%%   - INDIGO (tabState)            : Tabs et navigation principale
%%   - ROUGE (runningState)         : Match en cours et déclencheurs
%%   - ROUGE FONCÉ (terminalState)  : États terminaux sans retour
%%   - CYAN (testState)             : Tests actionneurs/ventouses
%%   - ROSE (msgboxState)           : Message boxes overlay
%%   - GRIS POINTILLÉ (legacyState) : Code legacy/désactivé
%%
%% STRUCTURE DE NAVIGATION:
%%
%% 1. TABS PRINCIPALES (Navigation manuelle):
%%    - Tab 1: CarteSD Status (spinners, labels SD card)
%%    - Tab 2: Match/Strategy (roller, color, GO button)
%%    - Tab 3: Test Actionneur (vacuum test interface)
%%    - Tab 4: Test (NOT IMPLEMENTED - empty)
%%
%% 2. OVERLAYS MODAL:
%%    - Message boxes apparaissent par-dessus les tabs
%%    - Bloquent l'interaction avec le reste de l'UI
%%    - Types: recalage, jack, generic, match message
%%
%% 3. FLUX PRINCIPAUX:
%%
%%    A. FLUX MATCH (Terminal):
%%       Tab 2 → Click GO → msgBoxmatchshow → run_show() thread
%%       → Match execution (100s) → NVIC_SystemReset() → Reboot
%%       ⚠️ Pas de retour arrière possible une fois lancé
%%
%%    B. FLUX VACUUM TEST (3 niveaux):
%%       Tab 3 → Click btnTestVentouses → Level 1 (side selection)
%%       → Level 2 (vacuum number) → Level 3 (action)
%%       → executeVentouse() → Retour Tab 3
%%       ✓ Annulation possible à chaque niveau
%%
%%    C. FLUX LEGACY (Désactivé):
%%       Tab 3 → Click test button → Robot side selection
%%       → Level selection matrix → Execute test → Retour idle
%%       ⚠️ Code commenté dans version actuelle
%%
%% 4. ÉVÉNEMENTS DE TRANSITION:
%%
%%    Event Type              | Source Object      | Handler Function               | Destination
%%    ----------------------- | ------------------ | ------------------------------ | -----------
%%    LV_EVENT_CLICKED        | depart button      | Ihm::eventHandler              | MATCH_FLOW
%%    LV_STATE_CHECKED        | btnTestVentouses   | Ihm::eventHandler              | VACUUM_TEST
%%    LV_EVENT_CLICKED        | Vacuum L1 buttons  | ventousesNiveau1EventHandler   | VACUUM_L2
%%    LV_EVENT_CLICKED        | Vacuum L2 buttons  | ventousesNiveau2EventHandler   | VACUUM_L3 or cancel
%%    LV_EVENT_CLICKED        | Vacuum L3 buttons  | ventousesNiveau3EventHandler   | Execute or back
%%    Tab button clicks       | Tab bar (manual)   | LVGL internal                  | Other tabs
%%    System events           | SD card detection  | main.cpp state machine         | Auto-switch Tab 2
%%
%% 5. FLAGS ET SYNCHRONISATION:
%%
%%    EventFlags (ihm.flags):
%%    - IHM_FLAG_DEPART               : GO button clicked → starts match
%%    - IHM_FLAG_Testventouse         : Vacuum test button (legacy, commented)
%%    - IHM_FLAG_Gradin_niveaux_2     : Construction test (legacy, commented)
%%    - IHM_FLAG_Niveaux_base         : Base level test (legacy, commented)
%%    - IHM_FLAG__Position_init       : Position init test (legacy, commented)
%%    - IHM_FLAG_Lacher               : Release test (legacy, commented)
%%    - IHM_FLAG__autre               : Other/JPO test (legacy, commented)
%%
%%    State Machine (main.cpp):
%%    - multi_init         : Idle state, waiting for user action
%%    - show_run_page      : Match started, run_show() thread running
%%    - test               : Actuator test execution (legacy)
%%    - test_ventouse_*    : Legacy vacuum test states (UNUSED)
%%
%% 6. VARIABLES D'ÉTAT:
%%
%%    Selection State (static in ihm.cpp):
%%    - selected_level (0-4)           : Level selection from button matrix
%%    - selected_ascenceur (1-4)       : Robot side (1=Avant, 2=Arrière, 3=Les Deux, 4=Annuler)
%%
%%    Vacuum Test State (public Ihm members):
%%    - ventousesCote (0-2)            : 0=Gauche, 1=Droite, 2=Les Deux
%%    - ventousesNumero (1-4)          : Vacuum number
%%    - ventousesAction (0-2)          : 0=Attraper, 1=Lâcher, 2=Les Deux
%%
%%    Strategy State (public Ihm members):
%%    - departCouleur (0-1)            : 0=Jaune, 1=Bleu
%%    - departStrategie (int)          : Strategy file index from roller
%%
%% 7. ÉTATS TERMINAUX:
%%
%%    - MATCH_RUNNING: Match en cours - pas de retour possible
%%      * Overlay modal bloque toute interaction
%%      * Seule sortie: NVIC_SystemReset() à la fin du match
%%      * Thread run_show() exécute machineStrategie()
%%
%%    - LEGACY_RESET: System reset si "Annuler" cliqué
%%      * Anciennement dans robot side selection
%%      * NVIC_SystemReset() → Reboot complet
%%
%% 8. AUTO-NAVIGATION:
%%
%%    - Seule navigation programmatique automatique:
%%      lv_tabview_set_act(tabView, 1, LV_ANIM_ON)
%%      Déclenché après chargement fichiers stratégie depuis SD
%%      Bascule automatiquement vers Tab 2 (Match/Strategy)
%%
%% 9. NAVIGATION BLOQUÉE:
%%
%%    - Tab 4 (Test) existe mais vide (testTabInit() non implémenté)
%%    - Pas de bouton "Retour" ou "Annuler" pendant le match
%%    - Message boxes modal empêchent accès aux tabs
%%    - Match overlay reste visible jusqu'à reset système
%%
%% 10. PATTERNS DE CONCEPTION:
%%
%%     - Event-Driven UI: LVGL callbacks set flags, main.cpp polls flags
%%     - State Machine Coordination: main.cpp state machine controls high-level flow
%%     - Modal Overlays: Message boxes block interaction, used for critical confirmations
%%     - Multi-Level Menus: Vacuum test uses 3-level nested navigation
%%     - Timeout Selections: Legacy system uses 5s timeouts for button choices
%%     - Thread Lifecycle: Match creates new Thread, terminated at end
%%
%% 11. CONTRAINTES ET LIMITATIONS:
%%
%%     - Pas de historique de navigation (no back stack)
%%     - Pas de breadcrumb trail pour navigation complexe
%%     - Mix de patterns: overlays + tabs + state machine
%%     - Code legacy coexiste avec nouveau système (refactoring partiel)
%%     - Message boxes non fermables par l'utilisateur (bloquants)
%%     - Auto-switch unique (Tab 1 → Tab 2), pas de routing intelligent
%%
%% 12. FICHIERS SOURCE:
%%
%%     - lib/ihm/ihm.cpp (lignes clés):
%%       * ligne 10    : ThreadLvgl creation
%%       * ligne 29    : carteSDInit() - Tab 1
%%       * ligne 92    : show() - Tab 2
%%       * ligne 213   : ActionneurInit() - Tab 3
%%       * ligne 367   : eventHandler() - Main event routing
%%       * ligne 435   : msgBoxRecalageInit()
%%       * ligne 461   : msgBoxJackInit()
%%       * ligne 488   : msgBoxInit() - Generic
%%       * ligne 518   : msgBoxmatchshow() - Match overlay
%%       * ligne 602   : showButtonSelectionBox() - Level selection
%%       * ligne 657   : showButtonascenceurBox() - Side selection
%%       * ligne 733   : showVentousesNiveau1() - Vacuum L1
%%       * ligne 684   : ventousesNiveau1EventHandler()
%%       * ligne 695   : ventousesNiveau2EventHandler()
%%       * ligne 712   : ventousesNiveau3EventHandler()
%%
%%     - src/main.cpp (lignes clés):
%%       * ligne 151   : type_etat enum definition
%%       * ligne 304   : main() - State machine loop
%%       * ligne 422   : multi_init state handler
%%       * ligne 525/534: new Thread(run_show) - Match thread creation
%%
%% 13. BUGS ET ISSUES POTENTIELS:
%%
%%     - msgBoxRecalage "Ok" button sets IHM_FLAG__autre (ligne 414)
%%       mais ce flag n'est jamais consommé par main.cpp dans version actuelle
%%     - testTabInit() appelée (ligne 205) mais jamais implémentée → Tab 4 vide
%%     - Code legacy massivement commenté sans être supprimé → confusion
%%     - Pas de vérification si SD card détachée pendant le match
%%     - NVIC_SystemReset() brutal - pas de cleanup propre des threads
%%
%% ========================================================================
